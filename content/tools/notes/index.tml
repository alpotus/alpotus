<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes Styler - Alpotus</title>
    
    <!-- Google Fonts for UI -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ------------------- */
        /* --- App Shell CSS (with Click-to-Toggle Sidebar) --- */
        /* ------------------- */
        :root {
            --primary-color: #f59e0b; --primary-hover: #fbbf24;
            --bg-color: #f8f9fa; --content-bg: #ffffff; --sidebar-bg: #111827;
            --text-color: #111827; --text-secondary: #4b5563; --border-color: #e5e7eb;
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            --sidebar-width: 260px; --topbar-height: 60px; --border-radius: 12px;
        }
        body.dark-mode {
            --bg-color: #121212; --content-bg: #1e1e1e; --sidebar-bg: #1e1e1e;
            --text-color: #e5e5e5; --text-secondary: #888888; --border-color: #2e2e2e;
            --shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; overflow: hidden; }
        body {
            font-family: 'Poppins', sans-serif; background-color: var(--bg-color); color: var(--text-color);
            transition: background-color 0.3s, color 0.3s; display: flex;
        }
        .sidebar {
            position: fixed; top: 0; left: 0; height: 100vh; width: var(--sidebar-width);
            background-color: var(--sidebar-bg); color: #e5e5e5; padding: 20px;
            display: flex; flex-direction: column; transform: translateX(-100%); /* Hidden by default */
            transition: transform 0.3s ease-in-out; z-index: 1000;
        }
        .sidebar.active { transform: translateX(0); }
        .main-content {
            width: 100%; display: flex; flex-direction: column;
            flex-grow: 1; height: 100vh;
        }
        .top-bar {
            height: var(--topbar-height); background-color: var(--content-bg);
            border-bottom: 1px solid var(--border-color); display: flex; align-items: center;
            padding: 0 20px; z-index: 900; box-shadow: var(--shadow); flex-shrink: 0;
        }
        #menu-btn {
            background: none; border: none; cursor: pointer; padding: 5px; z-index: 2;
        }
        #menu-btn svg { width: 24px; height: 24px; stroke: var(--text-color); }
        .app-title {
            position: absolute; left: 50%; transform: translateX(-50%);
            display: flex; align-items: center; gap: 10px; font-size: 1.2rem;
            font-weight: 600; color: var(--text-color);
        }
        .app-title svg { width: 28px; height: 28px; color: var(--primary-color); }
        .sidebar-header {
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;
        }
        .sidebar-logo { font-size: 1.5rem; font-weight: 600; }
        #close-sidebar-btn {
            background: none; border: none; color: #9ca3af; font-size: 1.5rem;
            cursor: pointer; transition: color 0.2s;
        }
        #close-sidebar-btn:hover { color: white; }
        .sidebar-nav ul { list-style: none; }
        .sidebar-nav li a {
            display: flex; align-items: center; gap: 12px; color: #d1d5db; text-decoration: none; padding: 15px;
            border-radius: 8px; font-weight: 500; transition: background-color 0.2s, color 0.2s; cursor: pointer;
        }
        .sidebar-nav li a:hover, .sidebar-nav li a.active {
            background-color: rgba(255, 255, 255, 0.1); color: white;
        }
        .page-container {
            padding: 30px; flex-grow: 1; overflow-y: auto; /* This makes the container scrollable */
        }
        h1.page-title { font-size: 2.5rem; margin-bottom: 30px; flex-shrink: 0; }
        .btn {
            display: inline-block; padding: 12px 28px; border-radius: 8px; font-size: 1rem;
            text-decoration: none; font-weight: 600; transition: all 0.2s ease;
            background-color: var(--primary-color); color: white; border: none; cursor: pointer;
        }
        .btn:hover { background-color: var(--primary-hover); transform: translateY(-2px); }
        .overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.5); z-index: 999;
            opacity: 0; visibility: hidden; transition: opacity 0.3s, visibility 0.3s;
        }
        .overlay.active { opacity: 1; visibility: visible; }
        
        /* ------------------- */
        /* --- Tool Specific CSS --- */
        /* ------------------- */
        #tool-workspace {
            background-color: var(--content-bg); padding: 30px;
            border-radius: var(--border-radius); box-shadow: var(--shadow);
            height: 100%; display: flex; flex-direction: column;
        }
        .tool-page { display: none; height: 100%; flex-direction: column; }
        .tool-page.active { display: flex; }
        .editor-controls { display: flex; flex-direction: column; gap: 20px; margin-bottom: 30px; }
        .control-group { display: flex; flex-direction: column; gap: 8px; }
        .control-group label { font-weight: 600; color: var(--text-secondary); }
        #template-selector {
            padding: 12px; font-size: 1rem; border-radius: 8px;
            border: 1px solid var(--border-color); background-color: var(--bg-color);
            color: var(--text-color); font-family: 'Poppins', sans-serif;
        }
        #notes-editor {
            width: 100%; flex-grow: 1; min-height: 300px; padding: 15px;
            font-family: 'Courier New', Courier, monospace; font-size: 15px;
            border: 1px solid var(--border-color); border-radius: 8px;
            resize: none; background-color: var(--bg-color); color: var(--text-color);
        }
        .editor-footer { margin-top: 20px; text-align: right; flex-shrink: 0; }
        #viewer-frame { width: 100%; height: 100%; border: 1px solid var(--border-color); border-radius: 8px; }
        #save-feedback { color: var(--primary-color); font-weight: 600; opacity: 0; transition: opacity 0.5s; margin-right: 20px; }
    </style>
</head>
<body class="light-mode">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">Alpotus Menu</span>
            <button id="close-sidebar-btn">&times;</button>
        </div>
        <nav class="sidebar-nav">
            <ul>
                <li><a id="nav-editor" class="active"><i class="fas fa-edit"></i> Editor</a></li>
                <li><a id="nav-viewer"><i class="fas fa-eye"></i> Viewer</a></li>
                <li><a id="nav-download"><i class="fas fa-download"></i> Download</a></li>
              
            </ul>
        </nav>
    </aside>

    <!-- Main Content Area -->
    <div class="main-content" id="main-content">
        <!-- Top Bar -->
        <header class="top-bar">
            <button id="menu-btn">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
            <div class="app-title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
                <span>Notes Styler</span>
            </div>
        </header>

        <!-- Page Container with Tool Workspace -->
        <main class="page-container" id="page-container">
            <h1 id="page-title" class="page-title">Editor</h1>
            
            <div id="tool-workspace">
                <!-- Editor Page -->
                <div id="editor-page" class="tool-page active">
                    <div class="editor-controls">
                        <div class="control-group">
                            <label for="template-selector">1. Select a Template</label>
                            <select id="template-selector"></select>
                        </div>
                    </div>
                    <div class="control-group" style="height: 100%; display: flex; flex-direction: column;">
                        <label for="notes-editor">2. Enter your Body HTML Code </label>
                        <textarea id="notes-editor" placeholder="<h1>My Main Title</h1><p>You can type **bold** text or *italic* text and it will be automatically fixed!</p><ul><li>Like this</li></ul>"></textarea>
                    </div>
                    <div class="editor-footer">
                        <span id="save-feedback">Saved!</span>
                        <button id="save-btn" class="btn"><i class="fas fa-save"></i> Save Changes</button>
                    </div>
                </div>

                <!-- Viewer Page -->
                <div id="viewer-page" class="tool-page">
                    <iframe id="viewer-frame" title="Note Preview"></iframe>
                </div>
            </div>
        </main>
    </div>
    
    <div class="overlay" id="overlay"></div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- 1. DEFINE ALL 21 TEMPLATES ---
        const templates = [
            { id: 'template-1', name: '1. Serene Meadow', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;700&family=Montserrat:wght@400;600&display=swap" rel="stylesheet"><style>:root{--bg:#f4f8f4;--text:#3a4f3a;--h1:#2c5d2c;--h2:#5d8c5d;--font-body:'Lora',serif;--font-head:'Montserrat',sans-serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fff;padding:3em;border-radius:8px;box-shadow:0 5px 15px rgba(0,0,0,.05);border-left:5px solid var(--h1)}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head)}#notes-container h1{color:var(--h1);font-size:2.5rem}#notes-container h2{color:var(--h2);margin-top:1.5em}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-2', name: '2. Vibrant Circuit', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&family=Orbitron:wght@700&display=swap" rel="stylesheet"><style>:root{--bg:#f0f4f8;--text:#333;--h1:#ff6f00;--h2:#0077c2;--accent:#e3f2fd;--font-body:'Roboto',sans-serif;--font-head:'Orbitron',sans-serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fff;padding:3em;border-radius:4px;border-top:5px solid var(--h1)}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head)}#notes-container h1{color:var(--h1);font-size:2.8rem;text-transform:uppercase}#notes-container h2{color:var(--h2);border-bottom:2px solid var(--accent);padding-bottom:.3em;margin-top:1.5em}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-3', name: '3. Rustic Canvas', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Caveat:wght@700&display=swap" rel="stylesheet"><style>:root{--bg:#faf3e0;--text:#5c4033;--h1:#8d6e63;--h2:#a1887f;--font-body:'Merriweather',serif;--font-head:'Caveat',cursive}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fffdfa;padding:3em;border:1px solid #d7ccc8;box-shadow:0 0 10px #d7ccc8}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head)}#notes-container h1{color:var(--h1);font-size:3.5rem}#notes-container h2{color:var(--h2);font-size:2.5rem;margin-top:1em}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-4', name: '4. Cyber Pulse', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;700&display=swap" rel="stylesheet"><style>:root{--bg:#0a0a1a;--text:#e0e0e0;--h1:#00ffff;--h2:#ff00ff;--font-body:'Exo 2',sans-serif;--font-head:'Exo 2',sans-serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#1a1a2e;padding:3em;border-radius:8px;border:1px solid var(--h1);box-shadow:0 0 20px var(--h2)}#notes-container h1{color:var(--h1);text-shadow:0 0 10px var(--h1)}#notes-container h2{color:var(--h2);text-shadow:0 0 8px var(--h2);margin-top:1.5em}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-5', name: '5. Polished Aurora', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"><style>:root{--bg:#eef2f3;--text:#2c3e50;--h1:#2c3e50;--h2:#34495e;--accent:linear-gradient(120deg,#a1c4fd 0%,#c2e9fb 100%);--font-body:'Lato',sans-serif;--font-head:'Playfair Display',serif}body{font-family:var(--font-body);background:var(--accent);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:rgba(255,255,255,.9);padding:3em;border-radius:10px;backdrop-filter:blur(10px)}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head)}#notes-container h1{color:var(--h1)}#notes-container h2{color:var(--h2);margin-top:1.5em;border-bottom:1px solid #bdc3c7}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-6', name: '6. Ethereal Sky', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;500&family=Josefin+Sans:wght@300;600&display=swap" rel="stylesheet"><style>:root{--bg:#f0f7ff;--text:#6b7d91;--h1:#8ab6d6;--h2:#a5c7e3;--font-body:'Quicksand',sans-serif;--font-head:'Josefin Sans',sans-serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fff;padding:3em;border-radius:15px}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head);font-weight:600}#notes-container h1{color:var(--h1)}#notes-container h2{color:var(--h2);margin-top:1.5em;font-weight:300}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-7', name: '7. Galaxy Vista', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"><style>:root{--bg:#000010;--text:#a0a0c0;--h1:#ffdd44;--h2:#44aaff;--accent:#202030;--font-body:'Space Mono',monospace;--font-head:'Space Mono',monospace}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:var(--accent);padding:3em;border-radius:5px}#notes-container h1{color:var(--h1);text-shadow:0 0 5px var(--h1)}#notes-container h2{color:var(--h2);margin-top:1.5em;text-shadow:0 0 5px var(--h2)}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-8', name: '8. Forest Trail', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;700&family=Amatic+SC:wght@700&display=swap" rel="stylesheet"><style>:root{--bg:#e8e4d8;--text:#4a442d;--h1:#2e4600;--h2:#4a6a1a;--font-body:'Cabin',sans-serif;--font-head:'Amatic SC',cursive}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fff;padding:3em;border-radius:3px}#notes-container h1, #notes-container h2, #notes-container h3{font-family:var(--font-head)}#notes-container h1{color:var(--h1);font-size:3.5rem}#notes-container h2{color:var(--h2);font-size:2.8rem;margin-top:1em}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-9', name: '9. Citrus Oasis', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet"><style>:root{--bg:#fff8e1;--text:#5d4037;--h1:#f57c00;--h2:#8bc34a;--font-body:'Poppins',sans-serif;--font-head:'Poppins',sans-serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em}#notes-container{max-width:800px;margin:0 auto;background-color:#fff;padding:3em;border-radius:20px}#notes-container h1{color:var(--h1);font-weight:700}#notes-container h2{color:var(--h2);margin-top:1.5em;border-left:4px solid var(--h2);padding-left:10px}</style></head><body><div id="notes-container">[USER_CONTENT_HERE]</div></body></html>`},
            { id: 'template-10', name: '10. Desert Horizon', content: `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;700&display=swap" rel="stylesheet"><style>:root{--bg:#fdf6e3;--text:#654f34;--h1:#8c6f4c;--h2:#a68b6a;--accent:#eee8d5;--font-body:'Cormorant Garamond',serif;--font-head:'Cormorant Garamond',serif}body{font-family:var(--font-body);background-color:var(--bg);color:var(--text);margin:0;padding:2em;font-size:18px}#notes-container{max-width:800px;margin:0 auto;background-color:#f5efde;padding:3em;border:1px solid #dcd3be}#notes-container h1{color:var(--

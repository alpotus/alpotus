<script>
    // 1. Theme Toggle Logic
    window.toggleTheme = function() {
        document.body.classList.toggle('dark-mode');
        const isDark = document.body.classList.contains('dark-mode');
        localStorage.setItem('alpotus_theme', isDark ? 'dark' : 'light');
        const btn = document.getElementById('tBtn');
        if(btn) btn.innerText = isDark ? 'DAY' : 'NIGHT';
    };

    // 2. View Switcher Logic (FIXED)
    window.setView = function(mode) {
        const vp = document.getElementById('viewport-meta');
        const dBtn = document.getElementById('dView');
        const mBtn = document.getElementById('mView');

        if (!vp) {
            console.error("Viewport meta tag not found!");
            return;
        }

        if(mode === 'desktop') {
            // Forces the phone to zoom out
            vp.setAttribute('content', 'width=1200, initial-scale=0.3'); 
            document.body.classList.add('force-desktop');
            if(dBtn) dBtn.classList.add('active');
            if(mBtn) mBtn.classList.remove('active');
        } else {
            // Standard mobile zoom
            vp.setAttribute('content', 'width=device-width, initial-scale=1.0');
            document.body.classList.remove('force-desktop');
            if(mBtn) mBtn.classList.add('active');
            if(dBtn) dBtn.classList.remove('active');
        }
    };
</script>
